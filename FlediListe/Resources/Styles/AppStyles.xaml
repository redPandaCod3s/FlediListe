<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    
     <!-- ── FARBEN ── -->
    <Color x:Key="BgDeep">#0A0C10</Color>
    <Color x:Key="BgCard">#111520</Color>
    <Color x:Key="BgCardHover">#1A2035</Color>
    <Color x:Key="AccentSkyBlue">#00B2EE</Color>
    <Color x:Key="AccentSeaGreen">#20B2AA</Color>
    <Color x:Key="AccentGreen">#00FF7F</Color>
    <Color x:Key="TextPrimary">#E8EDF5</Color>
    <Color x:Key="TextSecondary">#6B7A99</Color>
    <Color x:Key="TextMuted">#3D4766</Color>
    <Color x:Key="BorderSubtle">#1E2740</Color>
    <Color x:Key="DangerRed">#FF4757</Color>

    <!-- ── SCHRIFTEN ── -->
    <x:String x:Key="FontMono">RobotoMono</x:String>

    <!-- ── STYLES: LABEL ── -->
    <Style x:Key="HeadingLarge" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="CharacterSpacing" Value="1.5" />
    </Style>

    <Style x:Key="HeadingSmall" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource AccentSeaGreen}" />
        <Setter Property="CharacterSpacing" Value="3" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="LineHeight" Value="1.6" />
    </Style>

    <Style x:Key="MonoLabel" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource AccentSeaGreen}" />
        <Setter Property="FontFamily" Value="{StaticResource FontMono}" />
    </Style>

    <!-- ── STYLES: BUTTON ── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource AccentSeaGreen}" />
        <Setter Property="TextColor" Value="{StaticResource BgDeep}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="HeightRequest" Value="46" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource AccentSeaGreen}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="HeightRequest" Value="46" />
        <Setter Property="BorderColor" Value="{StaticResource AccentSeaGreen}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource DangerRed}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="2" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="HeightRequest" Value="46" />
        <Setter Property="BorderColor" Value="{StaticResource DangerRed}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <!-- ── STYLES: ENTRY / EDITOR ── -->
    <Style x:Key="TechEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="TechEditor" TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    
</ResourceDictionary>