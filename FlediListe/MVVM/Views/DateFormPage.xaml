<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.DateFormPage"
             xmlns:converter="clr-namespace:FlediListe.MVVM.Converter"
             BackgroundColor="{StaticResource BgDeep}">
    
    <ContentPage.Resources>
        <converter:DateOnlyConverter x:Key="DateOnlyConverter"/>
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- Row 0: Header -->
        <VerticalStackLayout>
            <Label Text="Neuer Termin"
                   Style="{StaticResource HeadingLarge}"
                   Margin="0,16,0,8"/>
        </VerticalStackLayout>
        
        <!-- Row 1: Formular -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,16,24,16" Spacing="16">
            
                <VerticalStackLayout Spacing="4">
                    <Label Text="Datum"
                           Style="{StaticResource MonoLabel}"
                           FontSize="12"/>
                    <DatePicker Date="{Binding LocDate, Converter={StaticResource DateOnlyConverter}}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource BgCard}"/>
                </VerticalStackLayout>
            
                <VerticalStackLayout Spacing="4">
                    <Label Text="Kolonie"
                           Style="{StaticResource MonoLabel}"
                           FontSize="12"/>
                    <Entry Style="{StaticResource TechEntry}"
                           Placeholder="Kolonie eingeben..."
                           Text="{Binding Colony}"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Anzahl Fledermäuse"
                           Style="{StaticResource MonoLabel}"
                           FontSize="12"/>
                    <Entry Style="{StaticResource TechEntry}"
                           Placeholder="0"
                           Keyboard="Numeric"
                           Text="{Binding NumberBats}"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Spacing="4">
                    <Label Text="Anzahl Tutoren"
                           Style="{StaticResource MonoLabel}"
                           FontSize="12"/>
                    <Entry Style="{StaticResource TechEntry}"
                           Placeholder="0"
                           Keyboard="Numeric"
                           Text="{Binding NumberTutors}"/>
                </VerticalStackLayout>
                
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Row 2: Buttons -->
        <VerticalStackLayout Grid.Row="2" Padding="24,16,24,32" Spacing="8">
            <Button Text="Termin speichern"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>
            <Button Text="Abbrechen"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"/>
        </VerticalStackLayout>
        
    </Grid>
    
</ContentPage>