<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.LocationPage"
             xmlns:viewModels="clr-namespace:FlediListe.MVVM.ViewModels"
             BackgroundColor="{StaticResource BgDeep}">
    
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        <Button Text="zurück zur Startseite"
                Style="{StaticResource SecondaryButton}"
                Margin="24,16,24,16"/>
        <!-- Header -->
        <VerticalStackLayout Grid.Row="1" Padding="24,48,24,0" Spacing="4">
            <Label Text="Standorte" Style="{StaticResource HeadingLarge}" />
        </VerticalStackLayout>
        
        <Button Grid.Row="3"
                Text="+ neuen Standort"
                Style="{StaticResource PrimaryButton}"
                Margin="24,16,24,32"/>
        
    </Grid>
    
    
</ContentPage>