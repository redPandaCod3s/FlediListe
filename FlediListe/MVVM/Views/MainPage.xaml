<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.MainPage"
             BackgroundColor="{StaticResource BgDeep}">
    
    <ScrollView>
        <VerticalStackLayout Padding="24, 48, 24, 32" Spacing="0">
            <!-- Header -->
            <Label Text="Fledermaus-Monitoring in Panama"
                   Style="{StaticResource MonoLabel}"
                   Margin="0,0,0,32"
                   FontSize="28"/>
            
            <Border StrokeThickness="2"
                    Stroke="{StaticResource AccentSeaGreen}"
                    StrokeShape="RoundRectangle 8"
                    Padding="20"
                    Margin="0,0,0,32">
                <Border.Background>
                    <LinearGradientBrush>
                            <GradientStop Color="#111520" Offset="0"/>
                            <GradientStop Color="#1A2035" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Sacco Fledermaus-Daten"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AccentSkyBlue}"
                           HorizontalOptions="Start"/>
                    <Label Text="In dieser App werden folgende Daten erfasst: &#10; &#x2022; Anlegen von Standorten &#10; &#x2022; Anlegen von Terminen innerhalb der Standorte&#10; &#x2022; Kommentare zu den Audio- und Video-Files"
                           Style="{StaticResource BodyText}"/>
                </VerticalStackLayout>
            </Border>
            
            <Label Text="Standorte antippen, um zu den Standorten zu gelangen"
                   Style="{StaticResource MonoLabel}"/>
            
            <Border BackgroundColor="{StaticResource BgCard}"
                    StrokeThickness="1"
                    Stroke="{StaticResource BorderSubtle}"
                    StrokeShape="RoundRectangle 8"
                    Padding="16"
                    Margin="0,0,0,32">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OnBorderTapped}"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout>
                    <Label Text="Standorte"
                           FontSize="12"
                           TextColor="{StaticResource TextMuted}"/>
                    <Label Text="{Binding LocationsCount}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AccentSeaGreen}"/>
                </VerticalStackLayout>
            </Border>
            
            <Border BackgroundColor="{StaticResource BgCard}"
                    StrokeThickness="1"
                    Stroke="{StaticResource BorderSubtle}"
                    StrokeShape="RoundRectangle 8"
                    Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Impressum"
                           FontSize="12"
                           TextColor="{StaticResource TextMuted}"/>
                    <Label Text="Viktor Maier - IT-Beratung und Entwicklung"
                           FontSize="14"
                           TextColor="{StaticResource AccentSkyBlue}"/>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="📧" FontSize="16"/>
                        <Label Text="viktor.maier@ikmail.com"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="🌐" FontSize="16"/>
                        <Label Text="https://github.com/redPandaCod3s/FlediListe"
                               TextColor="{StaticResource TextSecondary}"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="📍" FontSize="16"/>
                        <Label Text="DE, Flensburg"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
            </Border>
            
            
        </VerticalStackLayout>
        
    </ScrollView>

</ContentPage>