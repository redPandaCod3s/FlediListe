<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.DateDetailPage"
             xmlns:converter="clr-namespace:FlediListe.MVVM.Converter"
             BackgroundColor="{StaticResource BgDeep}">
    
    <ContentPage.Resources>
        <converter:InvertedBoolConverter x:Key="InverseBoolConverter" />
        <converter:BoolToYesConverter x:Key="BoolToYesConverter"/>
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <!-- Row 0: Buttons -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="24,16,24,16">
            <Button Text="zurück"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding ReturnToDatePage}"/>
            
            <Button Text="Löschen"
                    Style="{StaticResource SecondaryButton}"
                    BorderColor="{StaticResource DangerRed}"
                    TextColor="Red"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding SetEditingMode}"/>
            
            <Button Text="Löschen beenden"
                    Style="{StaticResource SecondaryButton}"
                    BorderColor="{StaticResource DangerRed}"
                    TextColor="Red"
                    IsVisible="{Binding IsEditMode}"
                    Command="{Binding SetEditingMode}"/>
            
        </HorizontalStackLayout>
            
        <!-- Row 1: Header -->
        <Label Grid.Row="1"
               Text="Einträge"
               Style="{StaticResource HeadingLarge}"
               Margin="24,16,24,16"/>
        
        <!-- Row 2: Liste -->
        <CollectionView Grid.Row="2"
                        Margin="24,8,24,0"
                        ItemsSource="{Binding FileEntries}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource BgCard}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderSubtle}"
                            StrokeShape="RoundRectangle 10"
                            Padding="16"
                            Margin="0,0,0,8">
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Grid RowDefinitions="Auto, Auto" 
                                      ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto"
                                      ColumnSpacing="12"
                                      HorizontalOptions="Fill">
                                    
                                    <Label Grid.Row="0" Grid.Column="0"
                                            Text="File"
                                            FontSize="13"
                                            TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding FileNumber}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="File-Komm."
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding FileComment}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                
                                    <Label Grid.Row="0" Grid.Column="2"
                                           Text="Ind."
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="2"
                                           Text="{Binding Individual}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                
                                    <Label Grid.Row="0" Grid.Column="3"
                                           Text="ÜS"
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="3"
                                           Text="{Binding Clipping, Converter={StaticResource BoolToYesConverter}}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    
                                    <Label Grid.Row="0" Grid.Column="4"
                                           Text="Video"
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="4" 
                                           Text="{Binding Video}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    
                                    <Label Grid.Row="0" Grid.Column="5"
                                           Text="Vi.Komm."
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="5" 
                                           Text="{Binding VideoComment}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                    
                                </Grid>
                            </VerticalStackLayout>
                            
                            <Button Grid.Column="1"
                                    Text="🗑️"
                                    BackgroundColor="Transparent"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.IsEditMode}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.DeleteFileEntry}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                            Path=BindingContext.TapItemCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
                
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="12" Margin="0,60,0,0">
                    <Label Text="⚡" FontSize="48" 
                           HorizontalOptions="Center"/>
                    <Label Text="KEINE EINTRÄGE VORHANDEN"
                           Style="{StaticResource MonoLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="Lege einen Eintrag an."
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
        
        <!-- Row 3: Button -->
        <VerticalStackLayout Grid.Row="3" Padding="24,16,24,32" Spacing="8">
            <Button Text="neuen Eintrag anlegen"
                    Margin="24,16,24,32"
                    Style="{StaticResource PrimaryButton}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding SaveNewFileEntry}"/>
            
            <HorizontalStackLayout>
                <VerticalStackLayout>
                    <Button Text="⏱️ Startzeit setzen"
                            Margin="24,16,24,32"
                            Style="{StaticResource PrimaryButton}"
                            BorderColor="{StaticResource AccentSkyBlue}"
                            TextColor="Black"
                            Command="{Binding SetStartTimeStamp}"/>
                    
                    <Label Text="{Binding StartTimeStamp}"
                            Margin="24,16,24,32"
                            Style="{StaticResource MonoLabel}"
                            TextColor="#009acd"/>
                    
                </VerticalStackLayout>
                
                <VerticalStackLayout>
                    <Button Text="⏱️ Endzeit setzen"
                            Margin="24,16,24,32"
                            FontSize="12"
                            Style="{StaticResource PrimaryButton}"
                            BorderColor="#009acd"
                            TextColor="Black"
                            Command="{Binding SetEndTimeStamp}"/>
                    
                    <Label Text="{Binding EndTimeStamp}"
                           Margin="24,16,24,32"
                           FontSize="12"
                           Style="{StaticResource MonoLabel}"
                           TextColor="#009acd"/>
                </VerticalStackLayout>
                
            </HorizontalStackLayout>
        </VerticalStackLayout>
        
    </Grid>
    
</ContentPage>