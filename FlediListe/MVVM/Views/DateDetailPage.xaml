<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.DateDetailPage"
             xmlns:converter="clr-namespace:FlediListe.MVVM.Converter"
             BackgroundColor="{StaticResource BgDeep}">
    
    <ContentPage.Resources>
        <converter:InvertedBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <!-- Row 0: Buttons -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="24,16,24,16">
            <Button Text="zurück"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding ReturnToDatePage}"/>
            
            <Button Text="Bearbeiten"
                    Style="{StaticResource SecondaryButton}"
                    BorderColor="{StaticResource AccentSkyBlue}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding SetEditingMode}"/>
            
            <Button Text="Bearbeiten beenden"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{Binding IsEditMode}"
                    Command="{Binding SetEditingMode}"/>
            
        </HorizontalStackLayout>
            
        <!-- Row 1: Header -->
        <Label Grid.Row="1"
               Text="Einträge"
               Style="{StaticResource HeadingLarge}"
               Margin="24,16,24,16"/>
        
        <!-- Row 2: Liste -->
        <CollectionView Grid.Row="2"
                        Margin="24,8,24,0"
                        ItemsSource="{Binding FileEntries}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource BgCard}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderSubtle}"
                            StrokeShape="RoundRectangle 10"
                            Margin="0,0,0,8">
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Grid RowDefinitions="Auto, Auto" 
                                      ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto"
                                      ColumnSpacing="12">
                                    
                                    <Label Grid.Row="0" Grid.Column="0"
                                            Text="File"
                                            FontSize="13"
                                            TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding FileNumber}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="Individuum"
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Individual}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextPrimary}"/>
                                
                                    <Label Grid.Row="0" Grid.Column="2"
                                           Text="Ta"/>
                                    
                                    <Label Text="{Binding DayTime}"
                                           FontSize="13"
                                           TextColor="{StaticResource TextMuted}"/>
                                    
                                </Grid>
                            </VerticalStackLayout>
                            
                            <Button Grid.Column="1"
                                    Text="🗑️"
                                    BackgroundColor="Transparent"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.IsEditMode}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.DeleteFileEntry}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                            Path=BindingContext.TapItemCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
                
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="12" Margin="0,60,0,0">
                    <Label Text="⚡" FontSize="48" 
                           HorizontalOptions="Center"/>
                    <Label Text="KEINE EINTRÄGE VORHANDEN"
                           Style="{StaticResource MonoLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="Lege einen Eintrag an."
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
        
        <!-- Row 3: Button -->
        <Button Grid.Row="3"
                Text="neuen Eintrag anlegen"
                Margin="24,16,24,32"
                Style="{StaticResource PrimaryButton}"
                IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                Command="{Binding SaveNewFileEntry}"/>

    </Grid>
    
</ContentPage>