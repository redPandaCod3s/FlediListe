<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlediListe.MVVM.Views.DateDetailPage"
             xmlns:converter="clr-namespace:FlediListe.MVVM.Converter"
             BackgroundColor="{StaticResource BgDeep}">
    
    <ContentPage.Resources>
        <converter:DateOnlyConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>
    
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <!-- Row 0: Buttons -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="24,16,24,16">
            <Button Text="zurück"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding ReturnToDatePage}"/>
            
            <Button Text="Bearbeiten"
                    Style="{StaticResource SecondaryButton}"
                    BorderColor="{StaticResource AccentSkyBlue}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding SetEditMode}"/>
            
            <Button Text="Bearbeiten beenden"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{StaticResource IsEditMode}"
                    Command="{Binding SetEditingMode}"/>
            
        </HorizontalStackLayout>
            
        <!-- Row 1: Header -->
        <Label Grid.Row="1"
               Text="Einträge"
               Style="{StaticResource HeadingLarge}"
               Margin="24,16,24,16"/>
        
        <!-- Row 2: Liste -->
        <CollectionView Grid.Row="2"
                        Margin="24,8,24,0"
                        ItemsSource="{Binding FileEntries}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="{StaticResource BgCard}"
                            StrokeThickness="1"
                            Stroke="{StaticResource BorderSubtle}"
                            StrokeShape="RoundRectangle 10"
                            Margin="0,0,0,8">
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding FileNumber}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"/>
                                
                                <Label Text="{Binding Individual}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextMuted}"/>
                                
                                <Label Text="{Binding DayTime}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextMuted}"/>
                            </VerticalStackLayout>
                            
                            <Button Grid.Column="1"
                                    Text="🗑️"
                                    BackgroundColor="Transparent"
                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.IsEditMode}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                    Path=BindingContext.DeleteFileEntry}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                            Path=BindingContext.TapItemCommand}"
                                CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
                
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="12" Margin="0,60,0,0">
                    <Label Text="⚡" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="KEINE EINTRÄGE VORHANDEN"
                           Style="{StaticResource MonoLabel}"/>
                    <Label Text="Lege einen Eintrag an."
                           Style="{StaticResource BodyText}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
        
        <!-- Row 3: Button -->
        <VerticalStackLayout Grid.Row="3" Padding="24,16,24,32" Spacing="8">
            <Button Text="neuen Eintrag anlegen"
                    Style="{StaticResource PrimaryButton}"
                    IsVisible="{Binding IsEditMode, Converter={StaticResource InverseBoolConverter}}"
                    Command="{Binding SaveNewFileEntry}"/>
            
            <Button Text="Änderungen speichern"
                    IsVisible="{Binding IsEditMode}"
                    BackgroundColor="{StaticResource AccentSkyBlue}"
                    Command="{Binding UpdateFileEntry}"/>
        </VerticalStackLayout>
    </Grid>
    
</ContentPage>